# =============================================================================
# flchrms VPS Deployment Configuration
# =============================================================================
# Copy this file to .env.deploy and fill in your values.
# This file is sourced by deploy/setup-vps.sh
#
# NEVER commit .env.deploy to version control!
# =============================================================================

# ── Server & Domain ──────────────────────────────────────────────────────────
# Your domain name — must already have DNS A record pointing to the VPS IP
DEPLOY_DOMAIN="hrms.yourdomain.com"

# Email for Let's Encrypt certificate notifications
DEPLOY_CERTBOT_EMAIL="admin@yourdomain.com"

# ── Git ──────────────────────────────────────────────────────────────────────
# Repository to clone (HTTPS or SSH)
DEPLOY_GITHUB_REPO="https://github.com/jy0ung/flchrms.git"

# Branch to deploy
DEPLOY_BRANCH="main"

# Directory on the server where the app will live
DEPLOY_APP_DIR="/var/www/flchrms"

# ── Supabase Cloud (Frontend — build-time) ───────────────────────────────────
# These are baked into the JS bundle at build time
VITE_SUPABASE_URL="https://tjzttyvczumqzwdgngvg.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# ── Supabase Cloud (CLI — migrations & edge functions) ───────────────────────
# Generate an access token at: https://supabase.com/dashboard/account/tokens
# Leave blank to skip automated migrations (you can push manually later)
SUPABASE_ACCESS_TOKEN=""
SUPABASE_PROJECT_ID="tjzttyvczumqzwdgngvg"
SUPABASE_DB_PASSWORD=""

# ── Email Notifications (Resend) ────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
# Leave blank to skip — the worker will default to stub (no-op) mode
RESEND_API_KEY=""
NOTIFICATION_EMAIL_FROM="noreply@yourdomain.com"
