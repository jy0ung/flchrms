# =============================================================================
# FL Group HRMS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before building.
#
#   cp .env.example .env
#   nano .env          # edit values
#   npm run build      # VITE_* vars are embedded at build time
# =============================================================================

# ---------------------------------------------------------------------------
# Frontend (Vite — baked into the static bundle at build time)
# ---------------------------------------------------------------------------

# Supabase project URL  (e.g. https://tjzttyvczumqzwdgngvg.supabase.co)
VITE_SUPABASE_URL=https://bmdmdppcbdklfbwksvtu.supabase.co

# Supabase anonymous / publishable key (safe to expose in the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJtZG1kcHBjYmRrbGZid2tzdnR1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIzMjk1NzYsImV4cCI6MjA4NzkwNTU3Nn0.Q8WG37liQZHCa_XnAW_sfYqRX1E3c0bbud-dco833j0

# Supabase project ID (used by CI and optional tooling)
VITE_SUPABASE_PROJECT_ID=bmdmdppcbdklfbwksvtu

# ---------------------------------------------------------------------------
# Supabase Edge Function — notification-email-worker
# (set these as Supabase secrets, NOT in the frontend .env)
#
#   supabase secrets set KEY=value --project-ref <project-id>
# ---------------------------------------------------------------------------

# SUPABASE_URL=              # auto-injected by Supabase runtime
# SUPABASE_SERVICE_ROLE_KEY= # auto-injected by Supabase runtime

# Email provider: stub | resend | postmark | webhook
# NOTIFICATION_EMAIL_PROVIDER=stub

# Sender address
# NOTIFICATION_EMAIL_FROM=noreply@example.com

# Optional reply-to
# NOTIFICATION_EMAIL_REPLY_TO=

# --- Resend provider ---
# RESEND_API_KEY=

# --- Postmark provider ---
# POSTMARK_SERVER_TOKEN=
# POSTMARK_MESSAGE_STREAM=outbound

# --- Webhook provider ---
# NOTIFICATION_EMAIL_WEBHOOK_URL=
# NOTIFICATION_EMAIL_WEBHOOK_AUTH_HEADER=
# NOTIFICATION_EMAIL_WEBHOOK_AUTH_VALUE=

# Worker authentication token (set in both Supabase secrets and your cron/caller)
# NOTIFICATION_WORKER_TOKEN=
