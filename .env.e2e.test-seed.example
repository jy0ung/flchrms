# Local/dev targeted seed credentials (generated by supabase/seeds/targeted_test_seed.sql)
# Copy to .env.e2e.test-seed, then export before running Playwright RBAC tests.

E2E_BASE_URL=http://127.0.0.1:4173

# Use mixed identifiers to exercise email / username / employee_id login support.
E2E_ADMIN_IDENTIFIER=admin@flchrms.test
E2E_ADMIN_PASSWORD=Test1234!

E2E_HR_IDENTIFIER=TST-HR-001
E2E_HR_PASSWORD=Test1234!

E2E_DIRECTOR_IDENTIFIER=director.test
E2E_DIRECTOR_PASSWORD=Test1234!

E2E_GENERAL_MANAGER_IDENTIFIER=TST-GM-001
E2E_GENERAL_MANAGER_PASSWORD=Test1234!

E2E_MANAGER_IDENTIFIER=manager@flchrms.test
E2E_MANAGER_PASSWORD=Test1234!

E2E_EMPLOYEE_IDENTIFIER=employee.test
E2E_EMPLOYEE_PASSWORD=Test1234!

# Optional: helps Phase 3B specs target a deterministic row in Team Leave.
E2E_PHASE3B_TARGET_LEAVE_ROW_TEXT="Evelyn Employee"
